# Cross-compile buddy for arm64 on x86 host (no QEMU, native speed)
ARG VERSION=1.0.0
ARG PARALLEL_WORKERS=8

# ============================================================
# Stage 1: Base environment (reuse ros2-core/humble:dev)
# ============================================================
FROM ros2-core/humble:dev AS base

ENV DEBIAN_FRONTEND=noninteractive

# buddy-specific arm64 dependencies (cross-compiler already in base)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ccache python3-setuptools python3-venv curl \
    libasound2-dev:arm64 \
    libwebrtc-audio-processing-dev:arm64 \
    libcurl4-openssl-dev:arm64 libssl-dev:arm64 \
    && rm -rf /var/lib/apt/lists/*

# Toolchain file
COPY docker/toolchain-aarch64.cmake /opt/toolchain-aarch64.cmake

# ROS 2 Humble (arm64 prebuilt)
COPY prebuilt/aarch64/ros2_core /opt/ros2_core
ENV COLCON_PREFIX_PATH=/opt/ros2_core

RUN pip3 install --no-cache-dir "empy==3.3.4" lark

# Prebuilt aarch64 dependencies
COPY prebuilt/aarch64/sherpa-onnx /opt/prebuilt/sherpa-onnx
COPY prebuilt/aarch64/onnxruntime /opt/prebuilt/onnxruntime
COPY prebuilt/aarch64/opencv /opt/prebuilt/opencv
COPY prebuilt/aarch64/rknn /opt/prebuilt/rknn

# ============================================================
# Stage 2: Build buddy (colcon cross-compile)
# ============================================================
FROM base AS build

ARG PARALLEL_WORKERS
ARG DEVICE=cpu

WORKDIR /workspace
COPY src/ src/
COPY cmake/ cmake/

# Symlink prebuilt/current to match CMakeLists convention
RUN mkdir -p prebuilt/aarch64 && \
    ln -s /opt/prebuilt/sherpa-onnx prebuilt/aarch64/sherpa-onnx && \
    ln -s /opt/prebuilt/onnxruntime prebuilt/aarch64/onnxruntime && \
    ln -s /opt/prebuilt/opencv prebuilt/aarch64/opencv && \
    if [ "$DEVICE" = "npu" ] && [ -d /opt/prebuilt/rknn/lib ]; then \
      ln -s /opt/prebuilt/rknn prebuilt/aarch64/rknn; \
    fi && \
    ln -s aarch64 prebuilt/current

SHELL ["/bin/bash", "-c"]
ENV CCACHE_DIR=/ccache
ENV CMAKE_PREFIX_PATH=/opt/prebuilt/opencv:/opt/prebuilt/sherpa-onnx:/opt/prebuilt/onnxruntime
RUN --mount=type=cache,target=/ccache \
    . /opt/ros2_core/setup.bash && \
    cmake_device_flag=""; \
    if [ "$DEVICE" = "npu" ]; then cmake_device_flag="-DWITH_RKNN=ON"; fi && \
    colcon --log-base output/log \
      build \
      --build-base output/build \
      --install-base output/install \
      --parallel-workers ${PARALLEL_WORKERS} \
      --cmake-args \
        --no-warn-unused-cli \
        -DCMAKE_TOOLCHAIN_FILE=/opt/toolchain-aarch64.cmake \
        -DCMAKE_EXPORT_COMPILE_COMMANDS=ON \
        -DCMAKE_C_COMPILER_LAUNCHER=ccache \
        -DCMAKE_CXX_COMPILER_LAUNCHER=ccache \
        -DBUILD_TESTING=OFF \
        -DBUILD_DEVICE=${DEVICE} \
        ${cmake_device_flag}

# ============================================================
# Stage 4: Package deb
# ============================================================
FROM base AS package

ARG VERSION
ARG DEVICE=cpu
WORKDIR /deb-root

RUN mkdir -p opt/buddy/bin opt/buddy/lib opt/buddy/lib/sherpa opt/buddy/models opt/buddy/params opt/buddy/etc opt/buddy/scripts \
            opt/buddy/services/llm opt/buddy/rkllm_server \
            lib/systemd/system \
            DEBIAN

# Binaries and libraries from build
COPY --from=build /workspace/output/install/ /tmp/install/
COPY --from=build /opt/prebuilt/ /tmp/prebuilt/
COPY --from=build /opt/ros2_core/lib/ /tmp/ros2_lib/
COPY --from=build /opt/ros2_core/opt/ /tmp/ros2_opt/
COPY --from=build /opt/ros2_core/share/ /tmp/ros2_share/

# Only the few system libs we actually need (no transitive dependency hell)
COPY --from=base /usr/lib/aarch64-linux-gnu/libasound.so* /tmp/syslib/
COPY --from=base /usr/lib/aarch64-linux-gnu/libcurl.so* /tmp/syslib/
COPY --from=base /usr/lib/aarch64-linux-gnu/libssl.so* /tmp/syslib/
COPY --from=base /usr/lib/aarch64-linux-gnu/libcrypto.so* /tmp/syslib/
COPY --from=base /usr/lib/aarch64-linux-gnu/libnghttp2.so* /tmp/syslib/

# Colcon install outputs
RUN cp /tmp/install/buddy_app/lib/buddy_app/buddy_main opt/buddy/bin/ && \
    find /tmp/install -name "*.so*" -type f -exec cp -n {} opt/buddy/lib/ \; && \
    find /tmp/install -name "*.so*" -type l -exec cp -nP {} opt/buddy/lib/ \;

# ROS 2 core libs
RUN find /tmp/ros2_lib -name "*.so*" -type f -exec cp -n {} opt/buddy/lib/ \; && \
    find /tmp/ros2_lib -name "*.so*" -type l -exec cp -nP {} opt/buddy/lib/ \; && \
    find /tmp/ros2_opt -name "*.so*" -type f -exec cp -n {} opt/buddy/lib/ \; && \
    find /tmp/ros2_opt -name "*.so*" -type l -exec cp -nP {} opt/buddy/lib/ \;

# Sherpa-ONNX (isolated: bundles its own ORT)
RUN cp -fP /tmp/prebuilt/sherpa-onnx/lib/*.so* opt/buddy/lib/sherpa/

# ONNX Runtime CPU (arm64 has no GPU variant)
RUN cp -fP /tmp/prebuilt/onnxruntime/lib/*.so* opt/buddy/lib/

# OpenCV
RUN cp -fP /tmp/prebuilt/opencv/lib/*.so* opt/buddy/lib/

# System libs
RUN cp -fP /tmp/syslib/* opt/buddy/lib/ 2>/dev/null || true

# RKNN (npu builds only — librknnrt.so)
RUN if [ "$DEVICE" = "npu" ] && [ -d /tmp/prebuilt/rknn/lib ]; then \
      cp -fP /tmp/prebuilt/rknn/lib/*.so* opt/buddy/lib/; \
    fi

# Params
COPY --from=build /workspace/output/install/buddy_app/share/buddy_app/params/ opt/buddy/params/

# ROS package metadata/index (ament): needed by class_loader/pluginlib at runtime.
# Merge ROS 2 core + workspace share trees into the packaged prefix.
RUN mkdir -p opt/buddy/share && \
    cp -a /tmp/ros2_share/. opt/buddy/share/ && \
    for d in /tmp/install/*/share; do \
      if [ -d "$d" ]; then cp -a "$d"/. opt/buddy/share/; fi; \
    done

# arm64+npu defaults:
# - Keep LLM on Ollama/CPU unless user explicitly overrides (avoid RKLLM startup/NPU contention issues)
# - Switch TTS to Melo RKNN so audio synthesis uses NPU by default
RUN if [ "$DEVICE" = "npu" ]; then \
      tts_cfg="opt/buddy/params/audio.tts.yaml"; \
      sed -i '/^[[:space:]]*tts:/,/^[[:space:]]*server:/ s/^\([[:space:]]*engine:\).*/\1 "melo-rknn"/' "$tts_cfg" && \
      sed -i '/^[[:space:]]*tts:/,/^[[:space:]]*server:/ s/^\([[:space:]]*runtime:\).*/\1 "rknnruntime"/' "$tts_cfg"; \
    fi

# Only include minimal keyword config needed at startup
COPY src/buddy_app/params/keywords.txt opt/buddy/params/keywords.txt

# Packaging files
COPY docker/packaging/run.sh opt/buddy/run.sh
COPY docker/packaging/buddy.env opt/buddy/etc/buddy.env
COPY docker/packaging/buddy.service lib/systemd/system/buddy.service
COPY docker/packaging/control.template DEBIAN/control
COPY docker/packaging/postinst DEBIAN/postinst
COPY docker/packaging/prerm DEBIAN/prerm
COPY docker/packaging/postrm DEBIAN/postrm
COPY scripts/common.sh opt/buddy/scripts/common.sh
COPY scripts/status.sh opt/buddy/scripts/status.sh
COPY scripts/start_llm_server.sh opt/buddy/scripts/start_llm_server.sh
COPY services/llm/ opt/buddy/services/llm/
COPY docker/rkllm_server/ opt/buddy/rkllm_server/

# Keep runtime package lean: strip local caches/tests/venv from bundled Python service sources.
RUN rm -rf opt/buddy/services/llm/.venv \
           opt/buddy/services/llm/tests \
           opt/buddy/services/llm/__pycache__ \
           opt/buddy/services/llm/backends/__pycache__ \
           opt/buddy/rkllm_server/.venv \
           opt/buddy/rkllm_server/__pycache__

RUN chmod 755 opt/buddy/run.sh opt/buddy/bin/buddy_main \
              opt/buddy/scripts/common.sh \
              opt/buddy/scripts/status.sh \
              opt/buddy/scripts/start_llm_server.sh \
              DEBIAN/postinst DEBIAN/prerm DEBIAN/postrm && \
    sed -i "s/__VERSION__/${VERSION}/" DEBIAN/control

RUN echo "BUDDY_TARGET_ARCH=arm64" >> opt/buddy/etc/buddy.env && \
    echo "BUDDY_TARGET_DEVICE=${DEVICE}" >> opt/buddy/etc/buddy.env

RUN mkdir -p /output && dpkg-deb --build /deb-root /output/buddy-robot_${VERSION}_arm64_${DEVICE}.deb

# ============================================================
# Stage 5: Models tarball (no compression, fast packaging)
# ============================================================
FROM base AS models

ARG VERSION
ARG DEVICE=cpu

WORKDIR /models-root
COPY models/ .
# Remove ollama (user pulls via ollama CLI on device)
RUN rm -rf ollama/
RUN rm -f *.tar* 2>/dev/null || true

# Device-specific model filtering
RUN if [ "$DEVICE" != "npu" ]; then \
      echo "[INFO] Excluding RKNN models (device=$DEVICE)"; \
      rm -rf zipformer-rknn/; \
      rm -rf melo-tts-rknn/; \
      rm -rf rkllm/; \
    else \
      echo "[INFO] Excluding server-only models for npu package"; \
      rm -rf funasr-paraformer-zh-offline/; \
      rm -rf funasr-paraformer-zh-online/; \
      rm -rf funasr-vad/; \
      rm -rf ChatTTS/; \
    fi

RUN mkdir -p /output && tar czf /output/buddy-models_${VERSION}_${DEVICE}.tar.gz -C /models-root .

# ============================================================
# Export both artifacts
# ============================================================
FROM scratch AS export-package
COPY --from=package /output/*.deb /

FROM scratch AS export-models
COPY --from=models /output/*.tar.gz /

FROM scratch AS export
COPY --from=package /output/*.deb /
COPY --from=models /output/*.tar.gz /
