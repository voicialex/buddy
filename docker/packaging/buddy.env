# Buddy Robot environment configuration
# Loaded by run.sh and start_llm_server.sh via `source`.

# LLM backend (rk_llm | ollama | cloud | vllm)
BUDDY_LLM_BACKEND=rk_llm

# Target device (cpu | gpu | npu) — used by status.sh for GPU detection
BUDDY_TARGET_DEVICE=npu

# ROS 2 distro (consumed by setup.bash at runtime)
BUDDY_ROS2_DISTRO=jazzy

# RKLLM model path. Relative paths resolve against the project root
# (this directory's parent), so the same env works under /opt/buddy or
# ~/out/opt/buddy. Use an absolute path only when the model lives outside.
BUDDY_RKLLM_MODEL_PATH=models/rkllm/Qwen2.5-3B-Instruct-rk3588-w8a8_g256-opt-0-hybrid-ratio-0.0.rkllm

# Ollama model override — only set when using a non-default model tag.
# BUDDY_OLLAMA_MODEL=qwen2.5:7b

# Cloud API key (optional — alternative to cloud.secret.yaml)
# DOUBAO_API_KEY=
