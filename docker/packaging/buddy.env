# Buddy Robot environment configuration
# Uncomment and modify as needed

# MIC_DEVICE=default
# SPEAKER_DEVICE=default
# DOUBAO_API_KEY=
# DOUBAO_MODEL_ID=

# Ollama uses its default model path (~/.ollama) by design.
# Set BUDDY_OLLAMA_MODEL only when you want a non-default model tag.

# Runtime platform hints (auto-generated in arm64 package build)
# BUDDY_TARGET_ARCH=arm64
# BUDDY_TARGET_DEVICE=cpu
# BUDDY_LLM_BACKEND=rk_llm
